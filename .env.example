# Jira Configuration
JIRA_SITE=https://your-site.atlassian.net
JIRA_USERNAME=your.email@example.com
JIRA_API_TOKEN=your_api_token_here

# Query Configuration
JIRA_PROJECT=PI
JIRA_JQL=project = "PI" AND "Incident detection datetime[Time stamp]" >= 2024-12-17 ORDER BY cf[10497] DESC

# Output Configuration
OUTPUT_DIR=./output
REPORT_PREFIX=PI-report
